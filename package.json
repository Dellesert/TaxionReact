{
  "name": "tachyon-messenger",
  "main": "node_modules/expo/AppEntry.js",
  "version": "1.0.1",
  "scripts": {
    "start": "expo start --port 8093 --host localhost",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "postinstall": "patch-package && node scripts/patch-zustand.js",
    "build:web": "npx expo export --platform web --output-dir dist",
    "generate:icons": "node scripts/generate-icons.js",
    "electron": "cross-env NODE_ENV=development electron ./electron/main.js",
    "electron:dev": "concurrently \"npm run start\" \"wait-on http://localhost:8093 && npm run electron\"",
    "electron:prebuild": "npm run generate:icons && npm run build:web && node scripts/fix-electron-paths.js && cd electron && npm install && cd ..",
    "electron:build": "npm run electron:prebuild && electron-builder",
    "electron:build:win": "npm run electron:prebuild && electron-builder --win",
    "electron:build:mac": "npm run electron:prebuild && electron-builder --mac",
    "electron:build:linux": "npm run electron:prebuild && electron-builder --linux",
    "electron:pack:win": "npm run electron:prebuild && electron-builder --win --dir",
    "electron:apply-icon": "node scripts/apply-icon.js"
  },
  "build": {
    "appId": "com.dellesert.tachyon-messenger",
    "productName": "Tachyon Messenger",
    "extends": null,
    "extraMetadata": {
      "main": "main.js"
    },
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron/resources",
      "app": "electron"
    },
    "files": [
      "**/*",
      {
        "from": "../dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "electron/../assets/images/icon_alpha.png",
        "to": "assets/images/icon_alpha.png"
      },
      {
        "from": "electron/resources/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "electron/resources/tray-icon-white.png",
        "to": "tray-icon-white.png"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-machine-id/**/*"
    ],
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/resources/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "signAndEditExecutable": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "electron/resources/icon.png",
      "category": "public.app-category.social-networking"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "icon": "electron/resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/resources/icon.ico",
      "uninstallerIcon": "electron/resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Tachyon Messenger"
    }
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-firebase/app": "^23.7.0",
    "@react-native-firebase/messaging": "^23.7.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@shopify/flash-list": "^2.0.2",
    "@tanstack/react-query": "^5.90.2",
    "axios": "^1.12.2",
    "babel-preset-expo": "~54.0.0",
    "date-fns": "^4.1.0",
    "electron-store": "^8.1.0",
    "expo": "~54.0.27",
    "expo-blur": "~15.0.8",
    "expo-constants": "^18.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.8",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.14",
    "expo-router": "~6.0.17",
    "expo-secure-store": "~15.0.8",
    "expo-share-intent": "^5.1.1",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.6.0",
    "node-machine-id": "^1.1.12",
    "react": "19.1.0",
    "react-datepicker": "^8.8.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.64.0",
    "react-native": "0.81.5",
    "react-native-blob-util": "^0.23.1",
    "react-native-file-viewer": "^2.1.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-mmkv": "^4.0.1",
    "react-native-nitro-modules": "^0.31.10",
    "react-native-passkey": "^3.3.1",
    "react-native-pdf": "^7.0.3",
    "react-native-reanimated": "^3.19.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "^4.20.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "^0.21.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "@types/react-datepicker": "^6.2.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "jest": "^29.2.1",
    "jest-expo": "~54.0.14",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "react-test-renderer": "19.0.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.3"
  },
  "private": true
}
