# ============================================
# Примеры конфигурации для разных платформ
# ============================================

# ----------------------------------------
# Android Эмулятор (AVD)
# ----------------------------------------
# Android эмулятор использует специальный IP для доступа к localhost хоста
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080/api/v1
# EXPO_PUBLIC_WS_URL=ws://10.0.2.2:8082

# ----------------------------------------
# iOS Симулятор
# ----------------------------------------
# iOS симулятор может использовать localhost напрямую
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
# EXPO_PUBLIC_WS_URL=ws://localhost:8082

# ----------------------------------------
# Физическое устройство (Android/iOS)
# ----------------------------------------
# Используйте IP-адрес вашего компьютера в локальной сети
# Узнать IP: ipconfig (Windows) или ifconfig (Mac/Linux)
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.160:8080/api/v1
# EXPO_PUBLIC_WS_URL=ws://192.168.1.160:8082

# ----------------------------------------
# Expo Go на физическом устройстве
# ----------------------------------------
# То же что и для физического устройства - IP вашего компьютера
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.160:8080/api/v1
# EXPO_PUBLIC_WS_URL=ws://192.168.1.160:8082

# ----------------------------------------
# Web (браузер)
# ----------------------------------------
# Для веб-версии используйте localhost
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
# EXPO_PUBLIC_WS_URL=ws://localhost:8082

# ============================================
# ВАЖНО!
# ============================================
# 1. Убедитесь, что бэкенд слушает на 0.0.0.0, а не только на 127.0.0.1
# 2. Убедитесь, что файрвол не блокирует порт 8080
# 3. Устройство и компьютер должны быть в одной сети
# 4. После изменения .env нужно перезапустить приложение
