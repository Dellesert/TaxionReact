# API Configuration
# For iOS/Android devices, replace localhost with your Mac's IP address
# Example: EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:8080/api/v1
# On production, use your domain: https://api.yourdomain.com/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
EXPO_PUBLIC_WS_URL=ws://localhost:8082

# JWT Configuration
EXPO_PUBLIC_JWT_SECRET=tachyon-super-secret-jwt-key-change-in-production-12345

# Environment
EXPO_PUBLIC_ENV=development
