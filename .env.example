# API Configuration
# For iOS/Android devices, replace localhost with your Mac's IP address
# Example: EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:8080/api/v1
# On production, use your domain: https://api.yourdomain.com/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
EXPO_PUBLIC_WS_URL=ws://localhost:8080

# JWT Configuration
EXPO_PUBLIC_JWT_SECRET=your-jwt-secret-here

# Environment
EXPO_PUBLIC_ENV=development

# Firebase Configuration (FCM для Web Push уведомлений)
# Получите эти значения из Firebase Console > Project Settings > General
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id
# VAPID Key для Web Push (Firebase Console > Project Settings > Cloud Messaging)
EXPO_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key

# Sentry DSN для отслеживания ошибок (https://sentry.io)
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here

# Android Signing (для локальной сборки release)
# Для CI/CD задавать через EAS Secrets или GitHub Actions secrets
ANDROID_KEYSTORE_PASSWORD=your-keystore-password
ANDROID_KEY_ALIAS=tachyon-release
ANDROID_KEY_PASSWORD=your-key-password
